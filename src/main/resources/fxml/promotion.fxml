<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.gym.controller.PromotionController"
            style="-fx-background-color: #f5f7fa;">
    
    <top>
        <VBox style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 15 20;">
                <Label text="🎁 QUẢN LÝ KHUYẾN MÃI" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="◄ Quay lại Dashboard" onAction="#handleBack" 
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            
            <!-- Table Section -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" 
                  style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="DANH SÁCH KHUYẾN MÃI" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                <Separator/>
                
                <TableView fx:id="tblPromotions" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colPromotionCode" text="Mã KM" prefWidth="120"/>
                        <TableColumn fx:id="colPromotionName" text="Tên khuyến mãi" prefWidth="200"/>
                        <TableColumn fx:id="colPromotionType" text="Loại" prefWidth="120"/>
                        <TableColumn fx:id="colDiscount" text="Giảm giá" prefWidth="120"/>
                        <TableColumn fx:id="colStartDate" text="Ngày BĐ" prefWidth="100"/>
                        <TableColumn fx:id="colEndDate" text="Ngày KT" prefWidth="100"/>
                        <TableColumn fx:id="colUsageCount" text="Đã dùng" prefWidth="100"/>
                        <TableColumn fx:id="colIsActive" text="Trạng thái" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Form Section -->
            <VBox spacing="15" prefWidth="450" 
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                <Label text="THÔNG TIN KHUYẾN MÃI" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
                <Separator/>
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox spacing="15">
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Mã khuyến mãi" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtPromotionCode" promptText="Tự động sinh mã"/>
                            </VBox>
                            <Button text="🎲 Tạo mã" onAction="#handleGenerateCode" 
                                    style="-fx-background-color: #3498db; -fx-text-fill: white;"
                                    prefHeight="25"/>
                        </HBox>
                        
                        <VBox spacing="5">
                            <Label text="Tên khuyến mãi *" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="txtPromotionName" promptText="VD: Giảm giá mùa hè"/>
                        </VBox>
                        
                        <VBox spacing="5">
                            <Label text="Mô tả" style="-fx-font-weight: bold;"/>
                            <TextArea fx:id="txtDescription" promptText="Mô tả chi tiết khuyến mãi" 
                                      prefRowCount="3" wrapText="true"/>
                        </VBox>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Loại khuyến mãi" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="cboPromotionType" prefWidth="200"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Loại giảm giá" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="cboDiscountType" prefWidth="150"/>
                            </VBox>
                        </HBox>
                        
                        <VBox spacing="5">
                            <Label text="Giá trị giảm giá *" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="txtDiscountValue" promptText="VD: 10 (10% hoặc 10,000 VNĐ)"/>
                        </VBox>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Đơn hàng tối thiểu" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtMinOrderAmount" promptText="VD: 1000000"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Giảm tối đa" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtMaxDiscountAmount" promptText="VD: 500000"/>
                            </VBox>
                        </HBox>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Ngày bắt đầu" style="-fx-font-weight: bold;"/>
                                <DatePicker fx:id="dpStartDate"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Ngày kết thúc" style="-fx-font-weight: bold;"/>
                                <DatePicker fx:id="dpEndDate"/>
                            </VBox>
                        </HBox>
                        
                        <HBox spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Giới hạn lượt dùng" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtUsageLimit" promptText="Để trống = không giới hạn"/>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Áp dụng cho" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="cboApplicableFor" prefWidth="150"/>
                            </VBox>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Trạng thái:" style="-fx-font-weight: bold;"/>
                            <CheckBox fx:id="chkIsActive" text="Đang hoạt động"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
                
                <Separator/>
                
                <HBox spacing="10" alignment="CENTER">
                    <Button text="➕ Thêm mới" onAction="#handleNew" 
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" 
                            prefWidth="100"/>
                    <Button text="💾 Lưu" onAction="#handleSave" 
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" 
                            prefWidth="100"/>
                    <Button text="🗑️ Xóa" onAction="#handleDelete" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" 
                            prefWidth="100"/>
                </HBox>
                
                <Label text="(*) Trường bắt buộc" style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>
            </VBox>
        </HBox>
    </center>
    
</BorderPane>